import string.ocrLite;
import string.ocrLite.defaultModels;
var ocr=string.ocrLite();

//配置文件（抵押类型及所用的文件/res/static.table）
var static_config=fsys.config("/res/").static;
var pledge_type=static_config.pledge_type;
var pledge_imgtype=static_config.pledge_imgtype;
var pledge_img_info=static_config.pledge_img_info;


//从配置文件读取上一次选取文件变量
winform.edit_selectFile.text=config.bdc.selectFileUrl;

//业务类型选择框
for(i=1;#pledge_type;1){
	winform.combobox_pledgetype.add(pledge_type[i])
}
//复选框控件变量
var checkbox_items={};
//获取文件按钮选择次数
var select_img_count = 0; 
winform.combobox_pledgetype.onOk  = function(id,event){
	checkbox_items={};
	//mainForm.edit_info.print(mainForm.combobox_pledgetype.selIndex);
	image_list=pledge_img_info[winform.combobox_pledgetype.selIndex]
	for(i=1;#image_list;1){
		if(image_list[i]){
			winform['checkbox'+i].setFont(strike=0);
			table.push(checkbox_items,i);
		}
		else {
			winform['checkbox'+i].setFont(strike=1);
		}
		//重绘控件 更新控件
		winform['checkbox'+i].checked=false;
		winform['checkbox'+i].redraw();
	}
	select_img_count=#checkbox_items;
	winform.button_selectfile.text="请选择"+pledge_imgtype[checkbox_items[#checkbox_items-select_img_count+1]]+"影像";
	winform.button_selectfile.disabled=false;
	//winform.button_GD.disabled=true;
	winform.button_ocr.disabled=true;
}


//选择文件路径框及按钮
var selectFileUrl=config.bdc.selectFileUrl;
winform.button_selectfile.oncommand = function(id,event){
	
	config.bdc.selectFileUrl=winform.edit_selectFile.text
	selectFileUrl=winform.edit_selectFile.text;
	img_type=pledge_imgtype[checkbox_items[#checkbox_items-select_img_count+1]];
	
	var file_path = fsys.dlg.openEx('所有文件|*.*|',"选择"+img_type,selectFileUrl); 
	if(!#file_path){return ;}
	file_dir=io.splitpath(file_path[1]).dir;
	file_type_dir=io.joinpath(file_dir,img_type);
	if(!io.exist(file_type_dir)){
		io.createDir(file_type_dir);
	}
	
	fsys.move(file_path,file_type_dir);

	winform["checkbox"+checkbox_items[#checkbox_items-select_img_count+1]].checked=true;
	
	select_img_count=select_img_count-1;
	
	
	if(select_img_count==1){
		if(winform['checkbox'+checkbox_items[#checkbox_items]].checked==false){
			select_img_count=select_img_count-1;
		}
	}
	
	if(select_img_count==0){
		owner.disabled=true;
		owner.text="图片选择完成";
		winform.button_GD.disabled=false;
		winform.button_ocr.disabled=false;
	}
	else {
		owner.disabled=false;
		owner.text="请选择"+pledge_imgtype[checkbox_items[#checkbox_items-select_img_count+1]]+"影像";
	}
	
}


