//编辑变更值会触发下面的事件
grid.onEditChanged = function(text,iItem,iSubItem){
	var name = datatable.fields[iSubItem];
	datatable[iItem][name] = text;
}



//从ocr结果的blocks属性获取客户身份证号index(替换Xx后全部为数字且大于10位数)
function getIdIndexs(ocr_blocks_result){
	var id_indexs={};
	for(i=1;#ocr_blocks_result;1){
		if(string.find(ocr_blocks_result[i].text,"号码")){
			var _text=string.split(ocr_blocks_result[i].text,"<号码>");
			_text=string.trim(_text[#_text]);
			if(tonumber(string.replace(_text,"(x)(X)",""))){
				if(tonumber(string.replace(_text,"(x)(X)",""))>1000000000){
					table.push(id_indexs,i);
				}
			}
		}
		elseif(tonumber(string.replace(ocr_blocks_result[i].text,"(x)(X)",""))){
			if(tonumber(string.replace(ocr_blocks_result[i].text,"(x)(X)",""))>1000000000){
				table.push(id_indexs,i);
			}
			
		}
	}
	
	return id_indexs; 
}

//获取两个点之间的距离
function distance(x_points,y_points){
	if(#x_points!=#y_points){
		return error("两个坐标点维度不相同"); 
	}
	else {
		var sum_distance=0;
		for(i=1;#x_points;1){
			sum_distance=sum_distance+(x_points[i]-y_points[i])**2;
		}
		return math.sqrt(sum_distance); 
	}
}

//从ocr结果的blocks属性获取客户姓名index（与客户身份证号块在1000范围内距离最远的块）
function getNameIndex(ocr_blocks_result,idIndexs){
	var name_indexs=0;
	var _dis=0;
	var x_points={ocr_blocks_result[idIndexs].points[1].x;ocr_blocks_result[idIndexs].points[1].y};
	for(i=1;#ocr_blocks_result;1){
		if(i==idIndexs){continue;}
		var y_points={ocr_blocks_result[i].points[1].x;ocr_blocks_result[i].points[1].y};
		var _d=distance(x_points,y_points);
		if(_d<1000 and _d>_dis){
			_dis=_d;
			name_indexs = i;
		}
	}
	return name_indexs; 
}

//格式化客户姓名
function format_name(_name)
{
	//去除首尾空白字符
	_name=string.trim(_name);
	//用空格拆分字符串，取末尾字符串内容
	var _n=string.split(_name," ");
	_name=_n[#_n];
	//用空字符串替换“姓名”
	_name=string.replace(_name,"姓名","");
	//客户姓名大于4则用名拆分数组
	if(#_name>4){
		_n=string.split(_name,"<名>");
		_name=_n[#_n];
	}
	return _name; 
}

//格式化客户证件号码
function format_id(_id)
{
	//去除首尾空白字符
	_id=string.trim(_id);
	//用空格拆分字符串，取末尾字符串内容
	var _i=string.split(_id," ");
	_id=_i[#_i];
	//用"号码"拆分字符串，取末尾字符串内容
	_i=string.split(_id,"<号码>");
	_id=_i[#_i];
	//用“0”字符串替换“Q”
	_id=string.replace(_id,"Q","0");
	//将小写x替换为大写X
	_id=string.replace(_id,"x","X");
	return _id; 
}


//OCR客户证件
winform.button_ocr.oncommand = function(id,event){
	
	var id_img_path=io.joinpath(winform.edit_selectFile.text,pledge_imgtype[3]);
	//var id_img_path="C:\Users\LCY\gitee\auto-work\文档及测试数据\客户身份信息";
	fsys.enum(id_img_path, "*.*",
		function(dir,filename,fullpath,findData){ 
			if(filename){ 
	           	//console.log("发现文件："+filename,"完整路径："+fullpath,"当前目录完整路径"+dir)
	           	ocr_result=ocr.detectImage(fullpath);
				ocr_blocks_result=ocr_result.blocks;
				id_indexs=getIdIndexs(ocr_blocks_result);
				for(i=1;#id_indexs;1)
				{
					index_name=getNameIndex(ocr_blocks_result,id_indexs[i]);
					//console.dump("姓名",format_name(ocr_blocks_result[index_name].text));
					//console.dump("身份证号",format_id(ocr_blocks_result[id_indexs[i]].text));
					table.push(datatable,{name=format_name(ocr_blocks_result[index_name].text);id=format_id(ocr_blocks_result[id_indexs[i]].text)});
				}
			}

		}
		,false/*如果此参数为false则忽略子目录*/
	);
	
	grid.setTable(datatable);
	
	mainForm.edit_info.print("OCR完成");
}


//给grid新增数据到末尾
winform.button_newperson.oncommand = function(id,event){
	table.push(datatable,{name=winform.edit_name.text;id=winform.edit_id.text;phone=winform.edit_phone.text});
	grid.setTable(datatable);
}

//影像归档
winform.button_GD.oncommand = function(id,event){
	var GD_path=io.splitpath(winform.edit_selectFile.text).dir;
	GD_path=io.joinpath(GD_path,pledge_type[winform.combobox_pledgetype.selIndex],tostring(time(time.now(),"%Y%m%d")));
	var dir_name="";
	for(i=1;#datatable;1){
		dir_name=dir_name+" "+datatable[i].name;
	}
	dir_name=string.trim(dir_name);
	var GD_path_name=io.joinpath(GD_path,dir_name);
	

	if(!io.exist(GD_path_name)){
		io.createDir(GD_path_name);
	}
	fsys.enum(winform.edit_selectFile.text, "*.*",
		function(dir,filename,fullpath,findData){ 
			fsys.move(fullpath,GD_path_name);
		} 
		,false/*如果此参数为false则忽略子目录*/
	);


	for(i=1;#datatable;1){
		var _d=table.pop(datatable);
		var person=Person();
		person.name=_d.name;
		person.id=_d.id;
		person.phone=_d.phone;
		table.push(pledge_info.persons,person);
	}
	
	pledge_info.image_path=GD_path_name;
	pledge_info.pldege_type=pledge_type[winform.combobox_pledgetype.selIndex];
	
	grid.setTable(datatable);
	winform.combobox_pledgetype.selIndex=null;
	
	mainForm.edit_info.print("影像归档完成");
}

winform.show();
win.loopMessage();
return winform;